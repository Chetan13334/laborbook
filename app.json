{
  "expo": {
    "name": "SiteBook",
    "slug": "laborbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo.icon/mobile-phone.png",
    "scheme": "SiteBook",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon/mobile-phone.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/expo.icon/mobile-phone.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.chetan1300.SiteBook"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./frontend/src/app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/expo.icon/mobile-phone.png",
            "imageWidth": 128
          }
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d09f1ade-1672-46fc-af3b-c27ada7d8d37"
      }
    }
  }
}
